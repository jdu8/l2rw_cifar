# Copy this to .env and fill in your values.
# .env is gitignored. train.py reads these automatically if you source the file
# or use a tool like `python-dotenv`. Alternatively, just export them in your shell.

# wandb — get your key at https://wandb.ai/authorize
WANDB_API_KEY=your_key_here

# Optional: pin the wandb entity (username or team) so you don't have to pass it every run.
# If omitted, wandb uses your default entity from `wandb login`.
WANDB_ENTITY=your_username_or_team
